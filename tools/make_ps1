            Write-Status "Cleaning: $path" "Gray"
            Remove-Item "$path\*" -Recurse -Force -ErrorAction SilentlyContinue
        }
    }
    
    Write-Success-Status "Clean completed"
}

# Function to build Node.js library
function Build-Node {
    param(
        [string]$Config,
        [string]$MSBUILD_PATH,
        [switch]$Verbose
    )
    
    Write-Status "Checking Node.js library..." "Cyan"
    if (-not (Ensure-RepoSubmodule -RepoRoot $PSScriptRoot -SubmodulePath "deps/node" -SentinelRelativePath "deps\node\src\node_version.h" -DisplayName "Node.js source checkout")) {
        Write-Error-Status "Node.js source checkout is required to build the node target."
        return 1
    }
    $nodeLibPath = "deps\node\out\$Config\lib\libnode.lib"
    $nodeExePath = "deps\node\out\$Config\node.exe"

    # Check if both required files exist
    $nodeLibExists = Test-Path $nodeLibPath
    $nodeExeExists = Test-Path $nodeExePath

    if (-not $nodeLibExists -or -not $nodeExeExists) {
        Write-Status "Building Node.js as a library..." "Yellow"
        
        Push-Location "deps\node"
        try {
            # Set environment to force single-threaded build to avoid hanging
            Write-Status "Running: cmd /c vcbuild.bat noprojgen nosign" "Gray"
            Write-Status "Using single-threaded build to prevent MSBuild hanging issues" "Yellow"
            $originalProcessors = $env:NUMBER_OF_PROCESSORS
            $env:NUMBER_OF_PROCESSORS = "1"
            $process = Start-Process -FilePath "cmd" -ArgumentList @("/c", "vcbuild.bat", "noprojgen", "nosign") -PassThru -NoNewWindow
            $timeout = 60 * 60 * 1000  # 60 minutes timeout for single-threaded Node.js build
            
            if ($process.WaitForExit($timeout)) {
                $BUILD_STATUS = $process.ExitCode
            } else {
                Write-Error-Status "Node.js build timed out after 60 minutes. Terminating process..."
                $process.Kill()
                $process.WaitForExit(10000)  # Wait up to 10 seconds for graceful termination
                if (!$process.HasExited) {
                    Write-Warning-Status "Process did not terminate gracefully, forcing kill..."
                    Stop-Process -Id $process.Id -Force
                }
                $BUILD_STATUS = 1
            }
            
            # Restore original processor count
            $env:NUMBER_OF_PROCESSORS = $originalProcessors
            
            if ($BUILD_STATUS -eq 0) {
                # Copy library files
                if (Test-Path "$Config\lib\*.lib") {
                    Copy-Item "$Config\lib\*.lib" "out\$Config\" -Force
                }
                if (Test-Path "build\$Config\lib\*.lib") {
                    Copy-Item "build\$Config\lib\*.lib" "out\$Config\" -Force
                }
            }
        }
        finally {
            Pop-Location
        }
        
        # Verify Node.js build actually succeeded by checking for required files
        $requiredFiles = @(
            "deps\node\out\$Config\lib\libnode.lib",
            "deps\node\out\$Config\node.exe"
        )
        
        $buildActuallySucceeded = $true
        foreach ($file in $requiredFiles) {
            if (-not (Test-Path $file)) {
                Write-Error-Status "Required Node.js file missing: $file"
                $buildActuallySucceeded = $false
            }
        }
        
        if ($buildActuallySucceeded) {
            Write-Success-Status "Node.js build verification passed - all required files present"
            $BUILD_STATUS = 0  # Override the exit code since build actually succeeded
        } else {
            Write-Error-Status "Node.js build failed - missing required files"
            $BUILD_STATUS = 1
        }
        
        if ($BUILD_STATUS -ne 0) {
            Write-Error-Status "Node.js build failed"
            return 1
        }
        
        # Clean up after Node.js build
        Cleanup-BuildProcesses
    }
    else {
        Write-Status "Skipping Node.js build because libnode.lib and node.exe already exist:" "Green"
        Write-Status "   libnode.lib" "Gray"
        Write-Status "   node.exe" "Gray"
    }

    # Copy node.exe to tools if needed
    if (-not (Test-Path "tools\node.exe")) {
        $null = Copy-File-If-Exists "deps\node\Release\node.exe" "tools\node.exe"
    }
    
    return 0
}

# Function to build the PDG Node.js module package
function Build-PDG-Node {
    param(
        [string]$Config,
        [string]$MSBUILD_PATH,
        [switch]$Verbose
    )

    Write-Host ""
    Write-Status "Building PDG Node.js module..." "Cyan"

    $status = Build-Node -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
    if ($status -ne 0) { return $status }

    $moduleScript = Join-Path $PDG_ROOT "tools\make-node-module.ps1"
    if (-not (Test-Path $moduleScript)) {
        Write-Error-Status "Missing script: $moduleScript"
        return 1
    }

    try {
        & $moduleScript -Config $Config
    }
    catch {
        Write-Error-Status "PDG Node.js module build failed: $($_.Exception.Message)"
        return 1
    }

    Write-Host ""
    Write-Success-Status "PDG Node.js module built successfully!"
    return 0
}

# Function to build GLFW library
function Build-GLFW {
    param(
        [string]$Config,
        [string]$MSBUILD_PATH,
        [switch]$Verbose
    )

    if ($script:PDG_HEADLESS_BUILD) {
        Write-Status "Skipping GLFW build because the current PDG configuration is headless." "Yellow"
        return 0
    }

    if (-not (Test-Path "build\win32\glfw\GLFW.sln")) {
        Write-Error-Status "GLFW is not configured. Run .\configure.ps1 without -Headless to generate the GLFW solution."
        return 1
    }

    Write-Status "Building GLFW Library..." "Yellow"
    Push-Location "build\win32\glfw"
    try {
        $BUILD_STATUS = Invoke-MSBuild -ProjectPath "GLFW.sln" -Target "Build" -Configuration $Config -MSBuildPath $MSBUILD_PATH -Verbose:$Verbose
        
        if ($BUILD_STATUS -eq 0) {
            # Copy glfw3.lib to src directory
            $null = Copy-File-If-Exists "src\$Config\glfw3.lib" "src\glfw3.lib"
        }
    }
    finally {
        Pop-Location
    }

    # Verify GLFW build actually succeeded by checking for the library file
    $glfwLibPath = "build\win32\glfw\src\$Config\glfw3.lib"
    if (Test-Path $glfwLibPath) {
        Write-Success-Status "GLFW build verification passed - glfw3.lib exists"
        $BUILD_STATUS = 0  # Override the exit code since build actually succeeded
    }

    if ($BUILD_STATUS -ne 0) {
        Write-Error-Status "GLFW build failed"
        return 1
    }

    # Clean up after GLFW build
    Cleanup-BuildProcesses
    return 0
}

