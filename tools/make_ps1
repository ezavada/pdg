# PDG Build Script (PowerShell)
# PowerShell version of make.bat that works with configure.ps1 results

param(
    [string]$Target = "pdg",
    [string]$Config = "Release",
    [switch]$Help,
    [switch]$Clean,
    [switch]$Verbose
)

# Note: Removed global MSBuild environment variable overrides to allow GLFW to use default settings

# Function to display help
function Show-Help {
    Write-Host "PDG Build Script (PowerShell)" -ForegroundColor Cyan
    Write-Host "=============================" -ForegroundColor Cyan
    Write-Host ""
    Write-Host "Usage: .\make.ps1 [options]" -ForegroundColor Yellow
    Write-Host ""
    Write-Host "Options:" -ForegroundColor Yellow
    Write-Host "  -Target <name>    Build target (default: pdg)" -ForegroundColor White
    Write-Host "  -Config <name>    Build configuration (default: Release)" -ForegroundColor White
    Write-Host "  -Clean            Clean build before building" -ForegroundColor White
    Write-Host "  -Verbose          Show full compiler/linker command lines (MSBuild detailed)" -ForegroundColor White
    Write-Host "  -Help             Show this help message" -ForegroundColor White
    Write-Host ""
    Write-Host "Available Targets:" -ForegroundColor Yellow
    Write-Host "  pdg               PDG app with Node.js JavaScript support (default)" -ForegroundColor White
    Write-Host "  pdg-node          PDG engine as a Node.js plugin" -ForegroundColor White
    Write-Host "  pdg-tests         C++ performance test suite (Bunnymark & PDGMark)" -ForegroundColor White
    Write-Host "  pdg-libs          C++ library suite (debug and optimized)" -ForegroundColor White
    Write-Host "  chipmunk          Chipmunk physics library" -ForegroundColor White
    Write-Host "  glfw              GLFW low level OpenGL graphics library" -ForegroundColor White
    Write-Host "  libjpeg-turbo     libjpeg-turbo JPEG image library" -ForegroundColor White
    Write-Host "  node              Node.js as a library and executable tool" -ForegroundColor White
    Write-Host "  clean             Clean everything except Node.js" -ForegroundColor White
    Write-Host ""
    Write-Host "This script builds PDG and all its dependencies using MSBuild." -ForegroundColor White
    Write-Host "Make sure to run .\configure.ps1 first to set up the build environment." -ForegroundColor White
}

# Show help if requested
if ($Help) {
    Show-Help
    exit 0
}

$submoduleHelperPath = Join-Path $PSScriptRoot "tools\submodules.ps1"
if (-not (Test-Path $submoduleHelperPath)) {
    $submoduleHelperPath = Join-Path $PSScriptRoot "submodules.ps1"
}
. $submoduleHelperPath

# Function to write colored output
function Write-Status {
    param([string]$Message, [string]$Color = "White")
    Write-Host $Message -ForegroundColor $Color
}

function Write-Error-Status {
    param([string]$Message)
    Write-Host "ERROR: $Message" -ForegroundColor Red
}

function Write-Success-Status {
    param([string]$Message)
    Write-Host "SUCCESS: $Message" -ForegroundColor Green
}

function Write-Warning-Status {
    param([string]$Message)
    Write-Host "WARNING: $Message" -ForegroundColor Yellow
}

# Function to check if a command exists
function Test-Command {
    param([string]$Command)
    try {
        Get-Command $Command -ErrorAction Stop | Out-Null
        return $true
    }
    catch {
        return $false
    }
}

function Test-PDGHeadlessConfigured {
    $cachePath = Join-Path (Get-Location).Path "msvc\CMakeCache.txt"
    if (-not (Test-Path $cachePath)) {
        return $false
    }

    return (Select-String -Path $cachePath -Pattern "^PDG_HEADLESS:BOOL=ON$" -Quiet)
}

# Function to find MSBuild
function Find-MSBuild {
    # Check if MSBuild is in PATH
    if (Test-Command "msbuild") {
        return "msbuild"
    }
    
    # Check for Visual Studio installations using vswhere
    $vsWhere = "${env:ProgramFiles(x86)}\Microsoft Visual Studio\Installer\vswhere.exe"
    if (Test-Path $vsWhere) {
        try {
            # Look for Visual Studio with C++ tools
            $vsInstall = & $vsWhere -latest -products * -requires Microsoft.VisualStudio.Component.VC.Tools.x86.x64 -property installationPath
            if ($vsInstall) {
                $msbuildPath = Join-Path $vsInstall "MSBuild\Current\Bin\MSBuild.exe"
                if (Test-Path $msbuildPath) {
                    return $msbuildPath
                }
                
                # Try older MSBuild versions
                $msbuildPath = Join-Path $vsInstall "MSBuild\15.0\Bin\MSBuild.exe"
                if (Test-Path $msbuildPath) {
                    return $msbuildPath
                }
            }
            
            # Look for Build Tools
            $buildToolsInstall = & $vsWhere -latest -products * -requires Microsoft.VisualStudio.Workload.VCTools -property installationPath
            if ($buildToolsInstall) {
                $msbuildPath = Join-Path $buildToolsInstall "MSBuild\Current\Bin\MSBuild.exe"
                if (Test-Path $msbuildPath) {
                    return $msbuildPath
                }
            }
        }
        catch {
            Write-Warning-Status "Error checking Visual Studio installations: $($_)"
        }
    }
    
    # Check common MSBuild locations
    $commonPaths = @(
        "C:\Program Files\Microsoft Visual Studio\2022\BuildTools\MSBuild\Current\Bin\MSBuild.exe",
        "C:\Program Files\Microsoft Visual Studio\2022\Community\MSBuild\Current\Bin\MSBuild.exe",
        "C:\Program Files\Microsoft Visual Studio\2022\Professional\MSBuild\Current\Bin\MSBuild.exe",
        "C:\Program Files\Microsoft Visual Studio\2022\Enterprise\MSBuild\Current\Bin\MSBuild.exe",
        "C:\Program Files (x86)\Microsoft Visual Studio\2019\BuildTools\MSBuild\Current\Bin\MSBuild.exe",
        "C:\Program Files (x86)\Microsoft Visual Studio\2019\Community\MSBuild\Current\Bin\MSBuild.exe",
        "C:\Program Files (x86)\Microsoft Visual Studio\2019\Professional\MSBuild\Current\Bin\MSBuild.exe",
        "C:\Program Files (x86)\Microsoft Visual Studio\2019\Enterprise\MSBuild\Current\Bin\MSBuild.exe"
    )
    
    foreach ($path in $commonPaths) {
        if (Test-Path $path) {
            return $path
        }
    }
    
    return $null
}

# Function to run MSBuild
function Invoke-MSBuild {
    param(
        [string]$ProjectPath,
        [string]$Target = "Build",
        [string]$Configuration = "Release",
        [string]$MSBuildPath,
        [switch]$Verbose = $false,
        [int]$TimeoutMinutes = 30
    )
    
    $args = @(
        $ProjectPath,
        "/m", # Allow multiple processes (original behavior)
        "/t:$Target",
        "/p:Configuration=$Configuration",
        "/p:TreatWarningsAsErrors=false",
        "/clp:NoSummary;NoItemAndPropertyList;Verbosity=minimal",
        "/nologo"
    )
    
    if ($Verbose) {
        # detailed = show full cl.exe/link.exe command lines with all parameters
        $args = $args -replace "Verbosity=minimal", "Verbosity=detailed"
    }
    
    Write-Status "Running: $MSBuildPath $($args -join ' ')" "Gray"
    Write-Status "Timeout set to $TimeoutMinutes minutes" "Gray"
    
    try {
        $process = Start-Process -FilePath $MSBuildPath -ArgumentList $args -PassThru -NoNewWindow
        $timeout = $TimeoutMinutes * 60 * 1000  # Convert to milliseconds
        
    if ($process.WaitForExit($timeout)) {
        # Clean up after successful build
        Cleanup-BuildProcesses
        return $process.ExitCode
        } else {
            Write-Error-Status "MSBuild timed out after $TimeoutMinutes minutes. Terminating process..."
            $process.Kill()
            $process.WaitForExit(5000)  # Wait up to 5 seconds for graceful termination
            if (!$process.HasExited) {
                Write-Warning-Status "Process did not terminate gracefully, forcing kill..."
                Stop-Process -Id $process.Id -Force
            }
            Cleanup-BuildProcesses
            return 1
        }
    }
    catch {
        Write-Error-Status "Failed to run MSBuild: $($_)"
        return 1
    }
}

# Function to kill stuck MSBuild processes
function Stop-StuckMSBuildProcesses {
    Write-Status "Checking for stuck MSBuild processes..." "Yellow"
    $msbuildProcesses = Get-Process | Where-Object {$_.ProcessName -eq "MSBuild"}
    
    if ($msbuildProcesses.Count -gt 0) {
        Write-Warning-Status "Found $($msbuildProcesses.Count) MSBuild processes running"
        foreach ($proc in $msbuildProcesses) {
            $runningTime = (Get-Date) - $proc.StartTime
            Write-Status "MSBuild PID $($proc.Id) running for $($runningTime.ToString('hh\:mm\:ss'))" "Gray"
            
            #if ($runningTime.TotalMinutes -gt 2) {
                Write-Warning-Status "Terminating stuck MSBuild process PID $($proc.Id)"
                try {
                    Stop-Process -Id $proc.Id -Force
                } catch {
                    Write-Error-Status "Failed to terminate process $($proc.Id): $($_)"
                }
            #}
        } 
    } else {
        Write-Success-Status "No MSBuild processes found"
    }
}

# Function to cleanup build processes after each build step
function Cleanup-BuildProcesses {
    Write-Status "Cleaning up build processes..." "Yellow"
    
    # Kill any lingering MSBuild processes
    $msbuildProcesses = Get-Process | Where-Object {$_.ProcessName -eq "MSBuild"} -ErrorAction SilentlyContinue
    if ($msbuildProcesses) {
        foreach ($process in $msbuildProcesses) {
                try {
                    $runningTime = (Get-Date) - $process.StartTime
                    Write-Status "Terminating MSBuild process PID $($process.Id) (running for $($runningTime.ToString('hh\:mm\:ss')))" "Gray"
                    Stop-Process -Id $process.Id -Force -ErrorAction SilentlyContinue
                } catch {
                    Write-Warning-Status "Failed to terminate MSBuild process PID $($process.Id): $($_)"
                }
        }
    }
    
    # Kill any mspdbsrv processes (symbol server)
    $symbolProcesses = Get-Process | Where-Object {$_.ProcessName -eq "mspdbsrv"} -ErrorAction SilentlyContinue
    if ($symbolProcesses) {
        foreach ($process in $symbolProcesses) {
            try {
                Write-Status "Terminating symbol server process PID $($process.Id)" "Gray"
                Stop-Process -Id $process.Id -Force
            } catch {
                Write-Warning-Status "Failed to terminate symbol server process PID $($process.Id): $($_)"
            }
        }
    }
    
    # Kill any hanging conhost processes
    $conhostProcesses = Get-Process | Where-Object {$_.ProcessName -eq "conhost" -and $_.CPU -eq 0} -ErrorAction SilentlyContinue
    if ($conhostProcesses) {
        foreach ($process in $conhostProcesses) {
            try {
                $runningTime = (Get-Date) - $process.StartTime
                if ($runningTime.TotalMinutes -gt 5) {
                    Write-Status "Terminating hanging conhost process PID $($process.Id)" "Gray"
                    Stop-Process -Id $process.Id -Force
                }
            } catch {
                Write-Warning-Status "Failed to terminate conhost process PID $($process.Id): $($_)"
            }
        }
    }
    
    # Brief pause to ensure cleanup
    Start-Sleep -Milliseconds 500
    
    Write-Success-Status "Build process cleanup completed"
}

# Function to copy file if source exists
function Copy-File-If-Exists {
    param(
        [string]$Source,
        [string]$Destination
    )
    
    if (Test-Path $Source) {
        Copy-Item $Source $Destination -Force
        Write-Status "Copied $Source to $Destination" "Gray"
        return $true
    }
    else {
        Write-Warning-Status "Source file not found: $Source"
        return $false
    }
}

