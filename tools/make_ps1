# Function to build PDG executable
function Build-PDG {
    param(
        [string]$Config,
        [string]$MSBUILD_PATH,
        [switch]$Verbose,
        [string]$MSBuildTarget = "Build"
    )
    
    $pdgExePath = "src\$Config\pdg.exe"
    Write-Status "Building PDG..." "Yellow"
    Push-Location "msvc"
    #delete the pdg.exe file
    Remove-Item $pdgExePath -Force -ErrorAction SilentlyContinue
    try {
        $BUILD_STATUS = Invoke-MSBuild -ProjectPath "PDG.sln" -Target $MSBuildTarget -Configuration $Config -MSBuildPath $MSBUILD_PATH -Verbose:$Verbose
    }
    finally {
        Pop-Location
    }

    # Verify PDG build actually succeeded by checking for the executable file
    $pdgExePath = "msvc\src\$Config\pdg.exe"
    if (Test-Path $pdgExePath) {
        Write-Success-Status "PDG build verification passed - pdg.exe exists"
        $BUILD_STATUS = 0  # Override the exit code since build actually succeeded
    } else {
        Write-Error-Status "PDG build verification failed - pdg.exe not found"
        $BUILD_STATUS = 1
    }

    if ($BUILD_STATUS -ne 0) {
        Write-Error-Status "PDG build failed"
        return 1
    }

    # Clean up after PDG build
    Cleanup-BuildProcesses
    
    # Copy final executables and files
    Write-Status "Copying final files..." "Yellow"

    # Copy pdg.exe to the locations the Windows test/debug workflows use
    $null = Copy-File-If-Exists "msvc\src\$Config\pdg.exe" "test\pdg-run.exe"
    $null = Copy-File-If-Exists "msvc\src\$Config\pdg.exe" "pdg.exe"

    # Copy debug.html
    $null = Copy-File-If-Exists "tools\debug.html" "test\debug.html"
    $null = Copy-File-If-Exists "tools\debug.html" "msvc\src\$Config\debug.html"
    
    return 0
}

# Function to build pdg-tests target
function Build-PDG-Tests {
    param(
        [string]$Config,
        [string]$MSBUILD_PATH,
        [switch]$Verbose
    )

    if ($script:PDG_HEADLESS_BUILD) {
        Write-Error-Status "pdg-tests is unavailable in a headless configuration. Re-run .\configure.ps1 without -Headless to build the performance tests."
        return 1
    }

    Write-Host ""
    Write-Status "Building C++ performance tests..." "Cyan"
    
    # Build dependencies first
    $status = Build-GLFW -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
    if ($status -ne 0) { return $status }
    
    $status = Build-Chipmunk -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
    if ($status -ne 0) { return $status }
    
    $status = Build-LibjpegTurbo -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
    if ($status -ne 0) { return $status }
    
    $status = Build-Node -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
    if ($status -ne 0) { return $status }
    
    # Build the bunnymark and pdgmark targets
    Write-Status "Building bunnymark and pdgmark..." "Yellow"
    Push-Location "msvc"
    try {
        # Build bunnymark (MSBuild may return non-zero for warnings e.g. LNK4098; verify exe exists)
        $BUILD_STATUS = Invoke-MSBuild -ProjectPath "PDG.sln" -Target "bunnymark" -Configuration $Config -MSBuildPath $MSBUILD_PATH -Verbose:$Verbose
        $bunnymarkExe = "src\$Config\bunnymark.exe"
        if ($BUILD_STATUS -ne 0 -and -not (Test-Path $bunnymarkExe)) {
            Write-Error-Status "bunnymark build failed"
            return 1
        }
        if ($BUILD_STATUS -ne 0 -and (Test-Path $bunnymarkExe)) {
            Write-Warning-Status "bunnymark had warnings but executable was produced"
        }

        # Build pdgmark (same: verify by output file)
        $BUILD_STATUS = Invoke-MSBuild -ProjectPath "PDG.sln" -Target "pdgmark" -Configuration $Config -MSBuildPath $MSBUILD_PATH -Verbose:$Verbose
        $pdgmarkExe = "src\$Config\pdgmark.exe"
        if ($BUILD_STATUS -ne 0 -and -not (Test-Path $pdgmarkExe)) {
            Write-Error-Status "pdgmark build failed"
            return 1
        }
        if ($BUILD_STATUS -ne 0 -and (Test-Path $pdgmarkExe)) {
            Write-Warning-Status "pdgmark had warnings but executable was produced"
        }
    }
    finally {
        Pop-Location
    }
    
    Cleanup-BuildProcesses
    
    # Create symlinks/copies to test directory
    Remove-Item "test\perf\cpp-bunnymark\bunnymark.exe" -Force -ErrorAction SilentlyContinue
    Remove-Item "test\perf\cpp-pdgmark\pdgmark.exe" -Force -ErrorAction SilentlyContinue

    function Copy-ExeIfFound {
        param([string]$ExeName, [string]$DestPath)
        $expected = "msvc\src\$Config\$ExeName.exe"
        if (Test-Path $expected) {
            Copy-Item $expected $DestPath -Force
            return $true
        }
        $found = Get-ChildItem -Path "msvc" -Filter "$ExeName.exe" -Recurse -ErrorAction SilentlyContinue | Select-Object -First 1
        if ($found) {
            Copy-Item $found.FullName $DestPath -Force
            return $true
        }
        return $false
    }
    $bunOk = Copy-ExeIfFound "bunnymark" "test\perf\cpp-bunnymark\bunnymark.exe"
    $pdgOk = Copy-ExeIfFound "pdgmark" "test\perf\cpp-pdgmark\pdgmark.exe"
    if (-not $bunOk) { Write-Warning "bunnymark.exe not found under msvc\ (expected msvc\src\$Config\bunnymark.exe)" }
    if (-not $pdgOk) { Write-Warning "pdgmark.exe not found under msvc\ (expected msvc\src\$Config\pdgmark.exe)" }
    
    Write-Host ""
    Write-Success-Status "C++ performance tests built successfully!"
    Write-Status "libpdg-lib.a created (pure C++ framework library)" "Green"
    Write-Host ""
    Write-Host "Run C++ Bunnymark:      .\test\perf\cpp-bunnymark\bunnymark.exe" -ForegroundColor White
    Write-Host "Run JS Bunnymark:       .\pdg test\perf\bunnymark\bunnymark.js" -ForegroundColor White
    Write-Host "Run C++ PDGMark:        .\test\perf\cpp-pdgmark\pdgmark.exe" -ForegroundColor White
    Write-Host "Run JS PDGMark:         .\pdg test\perf\pdgmark\pdgmark.js" -ForegroundColor White
    Write-Host ""
    
    return 0
}

# Function to build pdg-libs target
function Build-PDG-Libs {
    param(
        [string]$Config,
        [string]$MSBUILD_PATH,
        [switch]$Verbose
    )
    
    Write-Host ""
    Write-Status "Building PDG C++ libraries (debug and optimized)..." "Cyan"
    
    # Build dependencies first
    $status = Build-GLFW -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
    if ($status -ne 0) { return $status }
    
    $status = Build-Chipmunk -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
    if ($status -ne 0) { return $status }
    
    $status = Build-LibjpegTurbo -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
    if ($status -ne 0) { return $status }
    
    $status = Build-Node -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
    if ($status -ne 0) { return $status }
    
    # Build the pdg-libs target
    Write-Status "Building pdg-libs..." "Yellow"
    Push-Location "msvc"
    try {
        $BUILD_STATUS = Invoke-MSBuild -ProjectPath "PDG.sln" -Target "pdg-libs" -Configuration $Config -MSBuildPath $MSBUILD_PATH -Verbose:$Verbose
        if ($BUILD_STATUS -ne 0) {
            Write-Error-Status "pdg-libs build failed"
            return 1
        }
    }
    finally {
        Pop-Location
    }
    
    Cleanup-BuildProcesses
    
    Write-Host ""
    Write-Success-Status "PDG C++ libraries built successfully!"
    Write-Host "  - libpdg-lib.a (optimized, NDEBUG, -O3)" -ForegroundColor White
    Write-Host "  - libpdgd.a    (debug, DEBUG=1, -O0 -g3)" -ForegroundColor White
    Write-Host ""
    
    return 0
}

# Main script execution
Write-Host ""
Write-Host "PDG Build Script (PowerShell)" -ForegroundColor Cyan
Write-Host "=============================" -ForegroundColor Cyan
Write-Host ""

# Set up environment
$PDG_ROOT = Get-Location
$BUILD_STATUS = 0

# Clean if requested
if ($Clean) {
    Invoke-Clean
}

# Find MSBuild
Write-Status "Looking for MSBuild..." "Cyan"
$MSBUILD_PATH = Find-MSBuild

if (-not $MSBUILD_PATH) {
    Write-Error-Status "Could not find MSBuild. Please run .\configure.ps1 first or ensure Visual Studio is installed."
    exit 1
}

Write-Status "Found MSBuild at: $MSBUILD_PATH" "Green"

# Clean up any stuck MSBuild processes before starting
Stop-StuckMSBuildProcesses

$script:PDG_HEADLESS_BUILD = Test-PDGHeadlessConfigured
if ($script:PDG_HEADLESS_BUILD) {
    Write-Status "Detected headless PDG configuration (PDG_HEADLESS=ON)." "Cyan"
}

# Handle different targets
switch ($Target.ToLower()) {
    "pdg" {
        # Build all dependencies and PDG
        $status = Build-Node -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
        
        $status = Build-GLFW -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
        
        $status = Build-Chipmunk -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
        
        $status = Build-LibjpegTurbo -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
        
        $status = Build-PDG -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
        
        $status = Build-PDG-Node -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
        
        # Final cleanup to ensure all processes are terminated
        Cleanup-BuildProcesses
        
        Write-Host ""
        Write-Success-Status "Build Succeeded"
        Write-Host ""
        Write-Status "Build Summary:" "Cyan"
        Write-Host "- Main executable: pdg.exe" -ForegroundColor White
        Write-Host "- Test executable: test\pdg-run.exe" -ForegroundColor White
        Write-Host "- Configuration: $Config" -ForegroundColor White
        Write-Host "- Target: $Target" -ForegroundColor White
        Write-Host ""
        if ($script:PDG_HEADLESS_BUILD) {
            Write-Status "Headless build configured; GUI/client test runs are not available in this setup." "Green"
        }
        else {
            Write-Status "You can now run tests with: .\test\client or .\test\node" "Green"
        }
    }

    "pdg-node" {
        $status = Build-PDG-Node -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
    }
    
    "pdg-tests" {
        $status = Build-PDG-Tests -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
    }
    
    "pdg-libs" {
        $status = Build-PDG-Libs -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
    }
    
    "node" {
        $status = Build-Node -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
        
        Write-Host ""
        Write-Success-Status "Node.js build completed"
    }
    
    "glfw" {
        if ($script:PDG_HEADLESS_BUILD) {
            Write-Error-Status "GLFW is not configured in a headless build. Re-run .\configure.ps1 without -Headless to build it."
            exit 1
        }

        $status = Build-GLFW -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
        
        Write-Host ""
        Write-Success-Status "GLFW build completed"
    }
    
    "chipmunk" {
        $status = Build-Chipmunk -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
        
        Write-Host ""
        Write-Success-Status "Chipmunk build completed"
    }
    
    "libjpeg-turbo" {
        $status = Build-LibjpegTurbo -Config $Config -MSBUILD_PATH $MSBUILD_PATH -Verbose:$Verbose
        if ($status -ne 0) { exit 1 }
        
        Write-Host ""
        Write-Success-Status "libjpeg-turbo build completed"
    }
    
    "clean" {
        Invoke-Clean
        Write-Success-Status "Clean completed"
    }
    
    default {
        Write-Error-Status "Unknown target: $Target"
        Write-Host ""
        Show-Help
        exit 1
    }
}
