#!/bin/bash
# -----------------------------------------------
# configure
#
# an autoconf-like configure script to allow the standard
# > ./configure; make commands to be used to build PDG
#
# Written by Ed Zavada, 2012
# Copyright (c) 2012, Dream Rock Studios, LLC
#
# Permission is hereby granted, free of charge, to any person obtaining a
# copy of this software and associated documentation files (the
# "Software"), to deal in the Software without restriction, including
# without limitation the rights to use, copy, modify, merge, publish,
# distribute, sublicense, and/or sell copies of the Software, and to permit
# persons to whom the Software is furnished to do so, subject to the
# following conditions:
#
# The above copyright notice and this permission notice shall be included
# in all copies or substantial portions of the Software.
#
# THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS
# OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF
# MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN
# NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM,
# DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR
# OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE
# USE OR OTHER DEALINGS IN THE SOFTWARE.
#
# -----------------------------------------------

source tools/colors.sh
source tools/submodules.sh

PLATFORM=`uname -s | awk '{print tolower($0)}'`

# Initialize configuration variables
USE_GLFW="yes"
GLFW_TARG="glfw"
USE_SYSTEM_NODE="no"
USE_JAVASCRIPTCORE="no"
BUILD_JAVASCRIPTCORE="no"
BUILD_EMSCRIPTEN="no"
INSTALL_NODE_APP="no"
HAVE_EMSCRIPTEN="no"
BUILD_IOS="no"
HEADLESS_BUILD="no"
PDG_CMAKE_OPTIONS=""
HAVE_CMAKE="no"
HAVE_XCODE="no"
PARALLEL_MAKE_OPTIONS="--jobs=8"
NODE_STATIC_CONFIGURE_OPTIONS="--enable-static"
NODE_RUNTIME_CONFIGURE_OPTIONS=""
LIBJPEG_TARG="libjpeg-turbo"

if [ "$PLATFORM" == "linux" ]; then
    NODE_STATIC_CONFIGURE_OPTIONS="$NODE_STATIC_CONFIGURE_OPTIONS --without-node-snapshot"
    NODE_RUNTIME_CONFIGURE_OPTIONS="--without-node-snapshot"
    LIBJPEG_TARG=""
fi

if [ "$PDG_ROOT" == "" ]; then
	PDG_ROOT=`pwd`
fi

PDG_BUILD_BIN_DIR="\$(PDG_ROOT)/build/$PLATFORM/pdg/src"

# Process command line arguments
for arg in "$@"; do
    case "$arg" in
        --help)
            echo "Configure Options: "
            echo "  --help                - this page"
            if [ "$PLATFORM" == "darwin" ]; then 
                echo "  --with-native-window  - use native windowing system on Mac OS X builds"
            fi
            echo "  --headless            - build without GUI/graphics support"
            echo "  --use-system-node     - Use the Node.js tools already installed"
            echo "  --pure-js             - Build the pure JavaScript version of PDG using Emscripten"
            exit 0
            ;;
        --headless)
            HEADLESS_BUILD="yes"
            USE_GLFW="no"
            GLFW_TARG=""
            PDG_CMAKE_OPTIONS="-DPDG_HEADLESS=ON $PDG_CMAKE_OPTIONS"
            ;;
        --use-system-node)
            USE_SYSTEM_NODE="yes"
            ;;
        --pure-js)
            BUILD_EMSCRIPTEN="yes"
            ;;
        --with-native-window)
            if [ "$PLATFORM" == "darwin" ]; then
                echo "-- Option: Using native windowing system on Mac OS X"
                USE_GLFW="no"
                GLFW_TARG=""
            else
                echo "-- Warning: --with-native-window option is only valid on macOS"
            fi
            ;;
        *)
            echo "-- Warning: Unknown option '$arg'"
            ;;
    esac
done

echo -e "${HEAD}Setup Configure...${RESET}"
echo "Use: ./configure --help to see configure options"

if [ "$USE_SYSTEM_NODE" == "yes" ]; then
	echo "-- Option: Using tools from installed version of Node.js"
else
	echo "-- Option: Using included node.js tools"
fi

if [ "$HEADLESS_BUILD" == "yes" ]; then
    echo "-- Option: Building headless (GUI/graphics code excluded)"
fi

if [ "$PLATFORM" == "darwin" ]; then 
    PDG_BUILD_BIN_DIR="$PDG_BUILD_BIN_DIR/pdg.app/Contents/MacOS"
	# Check if --with-native-window was specified
	if [[ " $@ " =~ " --with-native-window " ]]; then
		USE_GLFW="no"
		GLFW_TARG=""
        PDG_CMAKE_OPTIONS="-DUSE_GLFW_MAC=OFF $PDG_CMAKE_OPTIONS"
	fi
# 	if [ -d "deps/javascriptcore" ]; then
# 		BUILD_JAVASCRIPTCORE="yes"
# 	fi
	if [ -d "ios/pdg.xcodeproj" ]; then
		BUILD_IOS="yes"
        USE_JAVASCRIPTCORE="yes"
	fi
    SHARED_LIB_EXT="dylib"
else
    SHARED_LIB_EXT="so"
fi


# ---------- Create .pdgrc --------------

echo "# This file automatically generated by configure script" > .pdgrc
echo "" >> .pdgrc
echo "export PDG_ROOT=$PDG_ROOT" >> .pdgrc
if [ "$USE_SYSTEM_NODE" == "yes" ]; then
    echo "export PDG_NODE=node" >> .pdgrc
    echo "export PDG_NODE_GYP=node-gyp" >> .pdgrc
    echo "export PDG_NPM=npm" >> .pdgrc
    echo "export PDG_JASMINE_NODE=jasmine-node" >> .pdgrc
    echo "export PDG_NODE_INSPECTOR=node-inspector" >> .pdgrc
    echo "export PDG_REPL=repl" >> .pdgrc
else
    echo "export PDG_NODE=$PDG_ROOT/tools/node" >> .pdgrc
    echo "export PDG_NODE_GYP=$PDG_ROOT/tools/node-gyp" >> .pdgrc
    echo "export PDG_NPM=$PDG_ROOT/tools/npm" >> .pdgrc
    echo "export PDG_JASMINE_NODE=$PDG_ROOT/tools/jasmine-node" >> .pdgrc
    echo "export PDG_NODE_INSPECTOR=$PDG_ROOT/tools/node-inspector" >> .pdgrc
    echo "export PDG_REPL=$PDG_ROOT/tools/repl" >> .pdgrc
fi
echo "export PATH=$PDG_ROOT/tools:\$PATH" >> .pdgrc
echo "source $PDG_ROOT/tools/colors.sh" >> .pdgrc

echo "-- created .pdgrc"


# ----------- Check for Required and Optional Tools ----------

echo -e "${HEAD}Finding tools...${RESET}"

command_exists () {
    type "$1" &> /dev/null ;
}

if command_exists cmake ; then
    CMAKE_INFO=`cmake -version`
    CMAKE_INFO=(${CMAKE_INFO// / })
    CMAKE_VERS=${CMAKE_INFO[2]}
    CMAKE_PATH=`which cmake`
	echo "-- Check for CMake: $CMAKE_PATH - found (version $CMAKE_VERS)"
	HAVE_CMAKE="yes"
else
	echo -e "-- Check for CMake: ${ERR}not found${RESET}"
fi

if [ "$PLATFORM" == "darwin" ]; then 
    if command_exists xcodebuild ; then
        HAVE_XCODE="yes"
        XCODE_PATH=`which xcodebuild`
        XCODE_VERS=`xcodebuild -version | head -n 1 | sed 's/[^0-9.]*\([0-9.]*\).*/\1/'`
        echo -e "-- Check for XCode - $XCODE_PATH - found (version $XCODE_VERS)"
    else
        echo -e "-- Check for Xcode - not found"
        echo "     XCode is available free though the Mac App Store"
        HAVE_XCODE="no"
    fi
fi

if command_exists bcpp ; then
    BCPP_PATH=`which bcpp`
    echo "-- Check for C++ Pretty Print: $BCPP_PATH - OK"
	CAN_BUILD_INTERFACES="yes"
	PDG_CMAKE_OPTIONS="-DCAN_BUILD_INTERFACES=ON $PDG_CMAKE_OPTIONS"
else
    echo -e "-- Check for C++ Pretty Print - ${WARN}NOT FOUND${RESET}"
    echo "     Optional: Build and install bpp to support rebuilding JavaScript bindings"
    echo "     bcpp can be found in: tools/bcpp.tar.zip"
	CAN_BUILD_INTERFACES="no"
fi

if [ "$BUILD_EMSCRIPTEN" == "yes" ]; then
    if command_exists em++ ; then
        HAVE_EMSCRIPTEN="yes"
        EMCC_PATH=`which emcc`
        EMXX_PATH=`which em++`
        EMCC_VERS=`emcc --version | head -n 1 | sed 's/[^0-9.]*\([0-9.]*\).*/\1/'`
        EMXX_VERS=`em++ --version | head -n 1 | sed 's/[^0-9.]*\([0-9.]*\).*/\1/'`
        echo -e "-- Check for Emscripten C Compiler - $EMCC_PATH - found (version $EMCC_VERS)"
        echo -e "-- Check for Emscripten C++ Compiler - $EMXX_PATH - found (version $EMXX_VERS)"
    else
        echo -e "-- Check for Emscripten C Compiler - ${WARN}NOT FOUND${RESET}"
        echo -e "-- Check for Emscripten C++ Compiler - ${WARN}NOT FOUND${RESET}"
        echo "     Install emscripten to support rebuilding pure JavaScript version of pdg"
        echo "     emscripten is at: <http://kripken.github.io/emscripten-site/docs/getting_started/downloads.html>"
        HAVE_EMSCRIPTEN="no"
        BUILD_EMSCRIPTEN="no"
    fi
fi

if command_exists node ; then
    HAVE_NODE="yes"
    NODE_PATH=`which node`
    NPM_PATH=`which npm`
    NODE_VERS=`node --version`
    NPM_VERS=`npm --version`
    echo -e "-- Check for Node.js - $NODE_PATH - found (version $NODE_VERS)"
    echo -e "-- Check for NPM - $NPM_PATH - found (version $NPM_VERS)"
else
    if [ "$USE_SYSTEM_NODE" == "no" ]; then
        echo -e "-- Check for Node.js - ${WARN}NOT FOUND${RESET}"
        echo -e "-- Check for NPM - ${WARN}NOT FOUND${RESET}"
        echo "     Optional: Install Node.js to run PDG as a server side node module"
        echo "     Node.js is at: <https://nodejs.org/en/download/>"
        HAVE_NODE="no"
    else
	    echo -e "-- Check for Node.js: ${ERR}not found${RESET}"
	    echo -e "-- Check for NPM: ${ERR}not found${RESET}"
        HAVE_NODE="no"
    fi
fi

echo -e "${HEAD}Checking required source dependencies...${RESET}"
if ! ensure_repo_submodule "$PDG_ROOT" "deps/node" "deps/node/src/node_version.h" "Node.js source checkout"; then
    echo -e "${ERR}FATAL ERROR: Missing Node.js source checkout${RESET}"
    exit 1
fi
if ! ensure_repo_submodule "$PDG_ROOT" "deps/SpriterPlusPlus" "deps/SpriterPlusPlus/spriterengine/spriterengine.h" "SpriterPlusPlus source checkout"; then
    echo -e "${ERR}FATAL ERROR: Missing SpriterPlusPlus source checkout${RESET}"
    exit 1
fi

echo -e "${HEAD}Cleaning up old junk...${RESET}"
rm -rf test/node_modules

# die if we don't have CMake

if [ "$HAVE_CMAKE" == "no" ]; then
	echo -e "${ERR}FATAL ERROR: Missing CMake${RESET}"
	echo "REQUIRED: Please install CMake v2.6 or later"
	echo "and make sure it can be found in your PATH."
	echo "CMake can be found at: <http://www.cmake.org/download/>"
	exit 1
fi

if [ "$USE_SYSTEM_NODE" == "yes" ]; then
    if [ "$HAVE_NODE" == "no" ]; then
        echo -e "${ERR}FATAL ERROR: Missing Node.js${RESET}"
        echo "REQUIRED: you chose configure option --use-system-node, but"
        echo "no Node.js version was found on your system."
        echo "Please install Node.js 4.2 or later and make sure it "
        echo "can be found in your PATH."
        echo "Node.js can be found at: <https://nodejs.org/en/download/>"
        exit 1
    fi
fi


# ----------- Configure everything ----------

# echo -e "${HEAD}Configuring Node.js Library...${RESET}"
# cd $PDG_ROOT/deps/node
# ./configure --enable-static
cd $PDG_ROOT

rm -rf build/$PLATFORM
mkdir -p build/$PLATFORM/chipmunk
if [ "$USE_GLFW" == "yes" ]; then
    mkdir -p build/$PLATFORM/glfw
fi
mkdir -p build/$PLATFORM/libjpeg-turbo
mkdir -p build/$PLATFORM/pdg
mkdir -p build/js/pdg

cp LICENSE tools/node-pdg/LICENSE
if [ "$BUILD_IOS" == "yes" ]; then
    cp ios/test/test-ios test/ios
    chmod 755 test/ios
fi

echo -e "${HEAD}Configuring Chipmunk Library...${RESET}"
CMAKE_OPTIONS="-Wno-dev -DBUILD_DEMOS=OFF"
echo "-- CMake options: $CMAKE_OPTIONS"
cd $PDG_ROOT/build/$PLATFORM/chipmunk
cmake $CMAKE_OPTIONS $PDG_ROOT/deps/chipmunk
cd $PDG_ROOT

if [ "$USE_GLFW" == "yes" ]; then
    echo -e "${HEAD}Configuring GLFW Library...${RESET}"
    CMAKE_OPTIONS="-Wno-dev -DGLFW_BUILD_EXAMPLES=OFF -DGLFW_BUILD_TESTS=OFF"
    echo "-- CMake options: $CMAKE_OPTIONS"
    cd $PDG_ROOT/build/$PLATFORM/glfw
    cmake $CMAKE_OPTIONS $PDG_ROOT/deps/glfw
    cd $PDG_ROOT
else
    echo "-- Skipping GLFW configuration (headless build)"
fi

# Configure libjpeg-turbo for Windows platforms and sync JPEG headers for Linux
if [ "$PLATFORM" == "linux" ]; then
    echo -e "${HEAD}Preparing JPEG headers...${RESET}"
    echo "-- Copying Unix/Linux jconfig.h for libjpeg-turbo headers..."
    cp $PDG_ROOT/src/sys/libjpeg-turbo/jconfig-unix.h $PDG_ROOT/deps/libjpeg-turbo/src/jconfig.h
    echo "-- Using system JPEG runtime on Linux; skipping bundled libjpeg-turbo build configuration"
elif [ "$PLATFORM" != "darwin" ]; then
    echo -e "${HEAD}Configuring libjpeg-turbo Library...${RESET}"
    
    # Copy appropriate jconfig.h based on platform
    echo "-- Copying Windows jconfig.h for libjpeg-turbo..."
    cp $PDG_ROOT/src/sys/libjpeg-turbo/jconfig-win32.h $PDG_ROOT/deps/libjpeg-turbo/src/jconfig.h
    
    CMAKE_OPTIONS="-Wno-dev -DWITH_SIMD=ON"
    echo "-- CMake options: $CMAKE_OPTIONS"
    cd $PDG_ROOT/build/$PLATFORM/libjpeg-turbo
    cmake $CMAKE_OPTIONS $PDG_ROOT/deps/libjpeg-turbo
    cd $PDG_ROOT
else
    echo "-- Skipping libjpeg-turbo configuration (not needed on macOS)"
fi

echo -e "${HEAD}Configuring PDG...${RESET}"
CMAKE_OPTIONS="$PDG_CMAKE_OPTIONS"
echo "-- CMake options: $CMAKE_OPTIONS"
cd $PDG_ROOT/build/$PLATFORM/pdg; cmake $CMAKE_OPTIONS $PDG_ROOT
cd $PDG_ROOT



# ----------- Makefile construction ----------

echo -e "${HEAD}Building Master Makefile...${RESET}"


# show the user what we are doing

if [ "$CAN_BUILD_INTERFACES" == "yes" ]; then
    echo "-- configure for building JavaScript V8 bindings with 'make js-interfaces'"
    if [ "$USE_JAVASCRIPTCORE" == "yes" ]; then
        echo "-- configure for building JavaScriptCore bindings with 'make js-interfaces'"
    else
        echo "-- configure with no JavaScriptCore bindings"    
    fi
    JS_INTERFACES_TARG="js-interfaces"
else
    echo "-- configure with no JavaScript V8 bindings"    
fi
if [ "$BUILD_IOS" == "yes" ]; then
    echo "-- configure for building iOS version with 'make pdg-ios'"
    cp $PDG_ROOT/ios/test/test-ios $PDG_ROOT/test/ios
    chmod 755 $PDG_ROOT/test/ios
else
    echo "-- configure without iOS build"    
fi
if [ "$BUILD_EMSCRIPTEN" == "yes" ]; then
    echo "-- configure for building pure JavaScript version with 'make pdg-js'"
    PDG_JS_TARG="pdg-js-rebuild"
else
    echo "-- configure without pure JavaScript build (use --pure-js to enable)"
fi
if [ "$HEADLESS_BUILD" == "yes" ]; then
    echo "-- configure for headless runtime builds with 'make pdg'"
    echo "-- configure without GUI performance test executables"
fi
if [ "$BUILD_JAVASCRIPTCORE" == "yes" ]; then
    echo "-- configure for building WebKit's JavaScriptCore from source with 'make jsc'"
	JSC_TARG="jsc"
else
    echo "-- configure without build of JavaScriptCore from source"    
fi
if [ "$HAVE_XCODE" == "yes" ]; then
    echo "-- configure for building XCode project files using 'make xcode'"
else
    echo "-- configure without XCode support"    
fi


echo "# This file automatically generated by ./configure script" > Makefile
echo "" >> Makefile
echo "include .pdgrc.mak" >> Makefile
echo "" >> Makefile
echo "NODE_LIB := \$(shell cd \$(PDG_ROOT)/deps/node/out/Release/ && ls libnode.a 2>/dev/null)" >> Makefile
echo "NODE_EXE := \$(shell cd \$(PDG_ROOT)/deps/node/out/Release/ && ls node 2>/dev/null)" >> Makefile
echo "" >> Makefile
echo "" >> Makefile



# -- target: all

echo "all: pdg pdg-docs pdg-node $PDG_JS_TARG $JSC_TARG" >> Makefile
echo "" >> Makefile



# -- target: pdg

if [ "$PLATFORM" != "darwin" ]; then
    echo "pdg: $GLFW_TARG chipmunk $LIBJPEG_TARG node $JS_INTERFACES_TARG" >> Makefile
else
    echo "pdg: $GLFW_TARG chipmunk node $JS_INTERFACES_TARG" >> Makefile
fi
echo "	cd \$(PDG_ROOT)/build/$PLATFORM/pdg; make $PARALLEL_MAKE_OPTIONS " >> Makefile
if [ "$PLATFORM" == "linux" ] && [ "$HEADLESS_BUILD" == "yes" ]; then
    echo "	ln -sf \$(PDG_ROOT)/tools/pdg-headless-runner.sh \$(PDG_ROOT)/pdg" >> Makefile
    echo "	ln -sf \$(PDG_ROOT)/tools/pdg-headless-runner.sh \$(PDG_ROOT)/test/pdg" >> Makefile
else
    echo "	ln -sf $PDG_BUILD_BIN_DIR/pdg \$(PDG_ROOT)/pdg" >> Makefile
    echo "	ln -sf $PDG_BUILD_BIN_DIR/pdg \$(PDG_ROOT)/test/pdg" >> Makefile
fi
echo "	cp -f \$(PDG_ROOT)/tools/debug.html $PDG_BUILD_BIN_DIR/" >> Makefile
echo "" >> Makefile



# -- target: pdg-docs

if [ "$CAN_BUILD_INTERFACES" == "yes" ]; then
    echo "pdg-docs: pdg" >> Makefile
    echo "	\$(PDG_ROOT)/tools/make-idl-javascript.sh" >> Makefile
    echo "" >> Makefile
fi



# -- target: pdg-node

echo "pdg-node: node-modules" >> Makefile
echo "	\$(PDG_ROOT)/tools/make-node-module.sh" >> Makefile
echo "" >> Makefile



# -- target: pdg-tests

if [ "$HEADLESS_BUILD" == "yes" ]; then
    echo "pdg-tests:" >> Makefile
    echo "	@echo \"pdg-tests is unavailable for headless builds. Re-run ./configure without --headless to build GUI performance tests.\"" >> Makefile
    echo "	@false" >> Makefile
else
echo "pdg-tests: $GLFW_TARG chipmunk node $JS_INTERFACES_TARG" >> Makefile
echo "	@echo \"Building C++ performance tests...\"" >> Makefile
echo "	cd \$(PDG_ROOT)/build/$PLATFORM/pdg; make bunnymark pdgmark" >> Makefile
echo "	@rm -f \$(PDG_ROOT)/test/perf/cpp-bunnymark/bunnymark" >> Makefile
if [ "$PLATFORM" == "darwin" ]; then
    echo "	ln -sf \$(PDG_ROOT)/build/$PLATFORM/pdg/src/bunnymark.app/Contents/MacOS/bunnymark \$(PDG_ROOT)/test/perf/cpp-bunnymark/bunnymark" >> Makefile
else
    echo "	ln -sf \$(PDG_ROOT)/build/$PLATFORM/pdg/src/bunnymark \$(PDG_ROOT)/test/perf/cpp-bunnymark/bunnymark" >> Makefile
fi
echo "	@rm -f \$(PDG_ROOT)/test/perf/cpp-pdgmark/pdgmark" >> Makefile
if [ "$PLATFORM" == "darwin" ]; then
    echo "	ln -sf \$(PDG_ROOT)/build/$PLATFORM/pdg/src/pdgmark.app/Contents/MacOS/pdgmark \$(PDG_ROOT)/test/perf/cpp-pdgmark/pdgmark" >> Makefile
else
    echo "	ln -sf \$(PDG_ROOT)/build/$PLATFORM/pdg/src/pdgmark \$(PDG_ROOT)/test/perf/cpp-pdgmark/pdgmark" >> Makefile
fi
echo "	@echo \"\"" >> Makefile
echo "	@echo \"✓ C++ performance tests built successfully!\"" >> Makefile
echo "	@echo \"✓ libpdg-lib.a created (pure C++ framework library)\"" >> Makefile
echo "	@echo \"\"" >> Makefile
echo "	@echo \"Run C++ Bunnymark:      ./test/perf/cpp-bunnymark/bunnymark\"" >> Makefile
echo "	@echo \"Run JS Bunnymark:       ./pdg test/perf/bunnymark/bunnymark.js\"" >> Makefile
echo "	@echo \"Run C++ PDGMark:        ./test/perf/cpp-pdgmark/pdgmark\"" >> Makefile
echo "	@echo \"Run JS PDGMark:         ./pdg test/perf/pdgmark/pdgmark.js\"" >> Makefile
echo "	@echo \"\"" >> Makefile
fi
echo "" >> Makefile



# -- target: pdg-libs

echo "pdg-libs: $GLFW_TARG chipmunk node $JS_INTERFACES_TARG" >> Makefile
echo "	@echo \"Building PDG C++ libraries (debug and optimized)...\"" >> Makefile
echo "	cd \$(PDG_ROOT)/build/$PLATFORM/pdg; make pdg-libs" >> Makefile
echo "	@echo \"\"" >> Makefile
echo "	@echo \"✓ PDG C++ libraries built successfully!\"" >> Makefile
echo "	@echo \"  - libpdg-lib.a (optimized, NDEBUG, -O3)\"" >> Makefile
echo "	@echo \"  - libpdgd.a    (debug, DEBUG=1, -O0 -g3)\"" >> Makefile
echo "	@echo \"\"" >> Makefile
echo "" >> Makefile



# -- target: pdg-ios

if [ "$BUILD_IOS" == "yes" ]; then
    echo "pdg-ios: $JSC_TARG" >> Makefile
    echo "	@\$(PDG_ROOT)/tools/pretty_xcodebuild.py -configuration Debug -project \$(PDG_ROOT)/ios/pdg.xcodeproj -target pdg-js -sdk iphonesimulator" >> Makefile
    echo "	@\$(PDG_ROOT)/tools/pretty_xcodebuild.py -project \$(PDG_ROOT)/ios/pdg.xcodeproj -target pdg-js -sdk iphoneos -arch \"armv6 armv7\"  CODE_SIGN_IDENTITY=\"\" CODE_SIGNING_REQUIRED=NO" >> Makefile
    echo "	@ln -sf \$(PDG_ROOT)/build/Debug-iphonesimulator/pdg-js.app \$(PDG_ROOT)/ios/pdg-js-sim.app" >> Makefile
    echo "	@ln -sf \$(PDG_ROOT)/build/Release-iphoneos/pdg-js.app \$(PDG_ROOT)/ios/pdg-js.app" >> Makefile
    echo "" >> Makefile
fi



# -- target: pdg-js
# -- target: pdg-js-rebuild

if [ "$HAVE_EMSCRIPTEN" == "yes" ]; then
    echo "pdg-js: $JS_INTERFACES_TARG" >> Makefile
    echo "	emmake make $PARALLEL_MAKE_OPTIONS -f \$(PDG_ROOT)/tools/pdg-js.mak" >> Makefile
    echo "" >> Makefile

    echo "pdg-js-rebuild: $JS_INTERFACES_TARG" >> Makefile
    echo "	emmake make $PARALLEL_MAKE_OPTIONS -f \$(PDG_ROOT)/tools/pdg-js.mak clean" >> Makefile
    echo "	emmake make $PARALLEL_MAKE_OPTIONS -f \$(PDG_ROOT)/tools/pdg-js.mak" >> Makefile
    echo "" >> Makefile
fi



# -- target: js-interfaces

if [ "$CAN_BUILD_INTERFACES" == "yes" ]; then
    echo "js-interfaces:" >> Makefile
    echo "	cd \$(PDG_ROOT)/build/$PLATFORM/pdg; make pdg_js2native" >> Makefile
    echo "	cd \$(PDG_ROOT)/build/$PLATFORM/pdg; make pdg_common_interfaces" >> Makefile
    echo "	cd \$(PDG_ROOT)/build/$PLATFORM/pdg; make pdg_v8_interfaces" >> Makefile
    if [ "$USE_JAVASCRIPTCORE" == "yes" ]; then
        echo "	cd \$(PDG_ROOT)/build/$PLATFORM/pdg; make pdg_jsc_interfaces" >> Makefile
    fi
    echo "" >> Makefile
fi



# -- target: fix-interface-timestamps

echo "fix-interface-timestamps:" >> Makefile
echo "	touch \$(PDG_ROOT)/src/bindings/generated/v8/pdg_script_impl.h" >> Makefile
echo "	touch \$(PDG_ROOT)/src/bindings/generated/v8/pdg_script_impl.cpp" >> Makefile
echo "	touch \$(PDG_ROOT)/src/bindings/generated/v8/pdg_interfaces.cpp" >> Makefile
echo "	touch \$(PDG_ROOT)/src/bindings/generated/v8/pdg_script_interface.h" >> Makefile
if [ "$USE_JAVASCRIPTCORE" == "yes" ]; then
echo "	touch \$(PDG_ROOT)/src/bindings/generated/jsc/pdg_script_impl.h" >> Makefile
echo "	touch \$(PDG_ROOT)/src/bindings/generated/jsc/pdg_script_impl.cpp" >> Makefile
echo "	touch \$(PDG_ROOT)/src/bindings/generated/jsc/pdg_interfaces.cpp" >> Makefile
echo "	touch \$(PDG_ROOT)/src/bindings/generated/jsc/pdg_script_interface.h" >> Makefile
fi
echo "" >> Makefile



# -- target: jsc

if [ "$BUILD_JAVASCRIPTCORE" == "yes" ]; then
    echo "jsc:" >> Makefile
    echo "	@\$(PDG_ROOT)/tools/pretty_xcodebuild.py -configuration Debug -project \$(PDG_ROOT)/deps/javascriptcore/JavaScriptCore.xcodeproj -target iOSJavaScriptCore -sdk iphoneos" >> Makefile
    echo "	@\$(PDG_ROOT)/tools/pretty_xcodebuild.py -configuration Debug -project \$(PDG_ROOT)/deps/javascriptcore/JavaScriptCore.xcodeproj -target iOSJavaScriptCore -sdk iphonesimulator" >> Makefile
    echo "	@\$(PDG_ROOT)/tools/pretty_xcodebuild.py -project \$(PDG_ROOT)/deps/javascriptcore/JavaScriptCore.xcodeproj -target iOSJavaScriptCore -sdk iphoneos -arch \"armv6 armv7\"" >> Makefile
    echo "	@tools/pretty_xcodebuild.py -project \$(PDG_ROOT)/deps/javascriptcore/JavaScriptCore.xcodeproj -target iOSJavaScriptCore -sdk iphonesimulator" >> Makefile
    echo "	@cd \$(PDG_ROOT)/build/javascriptcore; lipo -create Production-iphoneos/libiOSJavaScriptCore.a Production-iphonesimulator/libiOSJavaScriptCore.a -output libiOSJavaScriptCore.a" >> Makefile
    echo "	@cd \$(PDG_ROOT)/build/javascriptcore; lipo -create Debug-iphoneos/libiOSJavaScriptCore.a Debug-iphonesimulator/libiOSJavaScriptCore.a -output libiOSJavaScriptCore-Debug.a" >> Makefile
    echo "	@ln -sf Production-iphoneos/JavaScriptCore \$(PDG_ROOT)/build/javascriptcore/JavaScriptCore" >> Makefile
    echo "	@echo \"JavaScriptCore Libraries Built in \$(PDG_ROOT)/build/javascriptcore/:\"" >> Makefile
    echo "	@ls -al \$(PDG_ROOT)/build/javascriptcore/libiOSJavaScriptCore*.a" >> Makefile
    echo "" >> Makefile
fi



# -- target: node

echo "node:" >> Makefile
echo "ifneq (\$(NODE_LIB),libnode.a)" >> Makefile
echo "	cd \$(PDG_ROOT)/deps/node; ./configure $NODE_STATIC_CONFIGURE_OPTIONS && make $PARALLEL_MAKE_OPTIONS V=\"\" " >> Makefile
echo "	find \$(PDG_ROOT)/deps/node/out/Release/obj.target -name '*.a' -exec cp -f {} \$(PDG_ROOT)/deps/node/out/Release/ \;" >> Makefile
echo "endif" >> Makefile
if [ "$USE_SYSTEM_NODE" == "yes" ]; then
echo "	@command -v \$(PDG_NODE) >/dev/null || { echo \"System Node.js executable '\$(PDG_NODE)' was not found in PATH.\"; false; }" >> Makefile
echo "	@echo \"Using system Node.js executable: \$(PDG_NODE)\"" >> Makefile
else
echo "ifneq (\$(NODE_EXE),node)" >> Makefile
echo "	cd \$(PDG_ROOT)/deps/node; ./configure $NODE_RUNTIME_CONFIGURE_OPTIONS && make $PARALLEL_MAKE_OPTIONS V=\"\"" >> Makefile
echo "	find \$(PDG_ROOT)/deps/node/out/Release/obj.target -name '*.a' -exec cp -f {} \$(PDG_ROOT)/deps/node/out/Release/ \;" >> Makefile
echo "	cp \$(PDG_ROOT)/deps/node/out/Release/node \$(PDG_ROOT)/tools/" >> Makefile
echo "endif" >> Makefile
echo "	-@cd \$(PDG_ROOT)/deps/node/out/Release/; ls -al node" >> Makefile
fi
echo "	-@cd \$(PDG_ROOT)/deps/node/out/Release/; ls -al libnode.a" >> Makefile
echo "" >> Makefile



# -- target: node-clean

echo "node-clean:" >> Makefile
echo "	cd \$(PDG_ROOT)/deps/node; make distclean" >> Makefile
echo "" >> Makefile



# -- target: node-modules

echo "node-modules: node" >> Makefile
echo "	\$(PDG_ROOT)/tools/install-node-modules.sh " >> Makefile
echo "" >> Makefile



# -- target: chipmunk

echo "chipmunk:" >> Makefile
echo "	cd \$(PDG_ROOT)/build/$PLATFORM/chipmunk; make $PARALLEL_MAKE_OPTIONS chipmunk_static" >> Makefile
echo "" >> Makefile



# -- target: glfw

if [ "$USE_GLFW" == "yes" ]; then
echo "glfw:" >> Makefile
echo "	cd \$(PDG_ROOT)/build/$PLATFORM/glfw; make $PARALLEL_MAKE_OPTIONS glfw" >> Makefile
fi
echo "" >> Makefile



# -- target: libjpeg-turbo (Windows build or Linux informational target)

if [ "$PLATFORM" == "linux" ]; then
    echo "libjpeg-turbo:" >> Makefile
    echo "	@echo \"Linux uses the system JPEG runtime; no bundled libjpeg-turbo build is required.\"" >> Makefile
    echo "" >> Makefile
elif [ "$PLATFORM" != "darwin" ]; then
    echo "libjpeg-turbo:" >> Makefile
    echo "	cd \$(PDG_ROOT)/build/$PLATFORM/libjpeg-turbo; make $PARALLEL_MAKE_OPTIONS jpeg" >> Makefile
    echo "" >> Makefile
fi



# -- target: superclean

echo "superclean: node-clean clean" >> Makefile
echo "	rm -rf \$(PDG_ROOT)/build \$(PDG_ROOT)/xcode \$(PDG_ROOT)/msvc \$(PDG_ROOT)/package \$(PDG_ROOT)/Makefile \$(PDG_ROOT)/pdg" >> Makefile
echo "	rm -rf \$(PDG_ROOT)/tools/node \$(PDG_ROOT)/node_modules \$(PDG_ROOT)/.pdg*" >> Makefile
echo "	rm -rf \$(PDG_ROOT)tools/jasmine-node \$(PDG_ROOT)tools/node-gyp" >> Makefile
echo "	rm -rf \$(PDG_ROOT)tools/node-inspector \$(PDG_ROOT)tools/npm \$(PDG_ROOT)tools/repl" >> Makefile
if [ "$BUILD_IOS" == "yes" ]; then
    echo "	rm -rf \$(PDG_ROOT)/ios/build" >> Makefile
fi
echo "	cd \$(PDG_ROOT)/deps/node; make distclean" >> Makefile
echo "" >> Makefile



# -- target: clean

echo "clean:" >> Makefile
echo "	@mkdir -p \$(PDG_ROOT)/build/$PLATFORM/node-pdg" >> Makefile
echo "	@mkdir -p \$(PDG_ROOT)/build/js/chipmunk" >> Makefile
echo "	@mkdir -p \$(PDG_ROOT)/build/js/pdg" >> Makefile
echo "	cd \$(PDG_ROOT)/build/$PLATFORM/pdg; make clean" >> Makefile
echo "	-cd \$(PDG_ROOT)/build/$PLATFORM/node-pdg; make clean" >> Makefile
if [ "$BUILD_EMSCRIPTEN" == "yes" ]; then
    echo "	-make -f \$(PDG_ROOT)/tools/pdg-js.mak clean" >> Makefile
fi
echo "	-rm -f \$(PDG_ROOT)/test/perf/cpp-bunnymark/bunnymark" >> Makefile
echo "	-rm -f \$(PDG_ROOT)/test/perf/cpp-pdgmark/pdgmark" >> Makefile
echo "" >> Makefile



# -- target: xcode

if [ "$HAVE_XCODE" == "yes" ]; then
    echo "xcode:" >> Makefile
    echo "	@mkdir -p \$(PDG_ROOT)/xcode" >> Makefile
    echo "	cd \$(PDG_ROOT)/xcode; cmake -G Xcode .." >> Makefile
    echo "" >> Makefile
fi



# -- target: help

echo "help:" >> Makefile
echo "	@echo \"Targets:\"" >> Makefile
echo "	@echo \"help              - this information \"" >> Makefile
echo "	@echo \"pdg               - PDG app with Node.js JavaScript support\"" >> Makefile
if [ "$BUILD_IOS" == "yes" ]; then
    echo "	@echo \"pdg-ios           - PDG for iOS\"" >> Makefile
fi
echo "	@echo \"pdg-node          - PDG engine as a Node.js plugin\"" >> Makefile
if [ "$BUILD_EMSCRIPTEN" == "yes" ]; then
    echo "	@echo \"pdg-js            - PDG in pure JavaScript for running in a web browser\"" >> Makefile
    echo "	@echo \"pdg-js-rebuild    - rebuild pdg-js completely\"" >> Makefile
fi
if [ "$HEADLESS_BUILD" == "yes" ]; then
    echo "	@echo \"pdg-tests         - unavailable in headless builds\"" >> Makefile
else
    echo "	@echo \"pdg-tests         - C++ performance test suite (Bunnymark & PDGMark)\"" >> Makefile
fi
echo "	@echo \"pdg-libs          - C++ library suite (debug libpdgd.a and optimized libpdg-lib.a)\"" >> Makefile
echo "	@echo \"chipmunk          - Chipmunk physic library \"" >> Makefile
if [ "$USE_GLFW" == "yes" ]; then
    echo "	@echo \"glfw              - GLFW low level OpenGL graphics library \"" >> Makefile
fi
if [ "$PLATFORM" != "darwin" ]; then
    echo "	@echo \"libjpeg-turbo     - libjpeg-turbo JPEG image library \"" >> Makefile
fi
if [ "$BUILD_JAVASCRIPTCORE" == "yes" ]; then
    echo "	@echo \"jsc               - JavaScriptCore libraries (used by iOS)\"" >> Makefile
fi
if [ "$CAN_BUILD_INTERFACES" == "yes" ]; then
    echo "	@echo \"js-interfaces     - interface files for JavaScript bindings \"" >> Makefile
fi
echo "	@echo \"node              - Node.js as a library and executable tool\"" >> Makefile
echo "	@echo \"node-clean        - clean the Node.js build; forces time consuming full rebuild\"" >> Makefile
echo "	@echo \"node-modules      - Setup supporting Node.js modules\"" >> Makefile
echo "	@echo \"superclean        - clean everything, even this Makefile! Must use ./configure to continue afterwards \"" >> Makefile
echo "	@echo \"clean             - clean everything except Node.js \"" >> Makefile
if [ "$HAVE_XCODE" == "yes" ]; then
    echo "	@echo \"xcode             - create an Xcode project \"" >> Makefile
fi
echo "" >> Makefile


# -- target: .PHONY

if [ "$PLATFORM" != "darwin" ]; then
    if [ "$USE_GLFW" == "yes" ]; then
        echo ".PHONY : all config pdg pdg-ios pdg-js pdg-node pdg-tests pdg-libs chipmunk chipmunk-js glfw libjpeg-turbo jsc js-interfaces fix-interface-timestamps node node-modules superclean clean xcode help" >> Makefile
    else
        echo ".PHONY : all config pdg pdg-ios pdg-js pdg-node pdg-tests pdg-libs chipmunk chipmunk-js libjpeg-turbo jsc js-interfaces fix-interface-timestamps node node-modules superclean clean xcode help" >> Makefile
    fi
else
    if [ "$USE_GLFW" == "yes" ]; then
        echo ".PHONY : all config pdg pdg-ios pdg-js pdg-node pdg-tests pdg-libs chipmunk chipmunk-js glfw jsc js-interfaces fix-interface-timestamps node node-modules superclean clean xcode help" >> Makefile
    else
        echo ".PHONY : all config pdg pdg-ios pdg-js pdg-node pdg-tests pdg-libs chipmunk chipmunk-js jsc js-interfaces fix-interface-timestamps node node-modules superclean clean xcode help" >> Makefile
    fi
fi

echo "-- created ./Makefile (in $PDG_ROOT)"

# ----------- end of Makefile construction ----------


