          "label": "Linux Node plugin",
          "paths": [
            "node_modules/pdg/package.json",
            "node_modules/pdg/lib/pdg.js",
            "node_modules/pdg/build/Release/pdg.node"
          ],
          "freshnessPath": "node_modules/pdg/build/Release/pdg.node",
          "staleInputs": [
            "src",
            "tools/node-pdg",
            "tools/make-node-module.sh",
            "tools/copy-node-module-source.sh"
          ],
          "buildCommands": [
            "./configure --headless --use-system-node",
            "make pdg",
            "make pdg-node"
          ]
        }
      ],
      "steps": [
        {
          "name": "Node spec suite",
          "command": "./test/node"
        }
      ]
    },
    {
